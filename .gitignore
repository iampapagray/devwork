# Build output (GoReleaser writes to dist/; the tracked ./devwork is the
# reference bash script, so it is intentionally NOT ignored)
/dist/
/devwork-bin
*.exe

# Generated by GoReleaser's before-hooks
/completions/

# Local credential file (the global config lives in ~/.config/devwork)
config.toml

# Editor / OS noise
.DS_Store
*.swp

# Local Claude Code settings
/.claude/

# Internal planning doc + the superseded bash reference script (kept locally,
# not published)
/PLAN.md
/devwork
